{
  "builds": [
    { "src": "server/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/css/(.*)", "dest": "server/index.js" },
    { "src": "/js/(.*)", "dest": "server/index.js" },
    { "src": "/images/(.*)", "dest": "server/index.js" },
    { "src": "/components/(.*)", "dest": "server/index.js" },
    { "src": "/blog/(.*)", "dest": "server/index.js" },
    { "src": "/(.*)\\.(css|js|png|jpg|jpeg|gif|svg|ico|webmanifest|txt|xml)", "dest": "server/index.js" },
    { "src": "/(.*)", "dest": "server/index.js" },
    { "src": "/style.css", "dest": "/public/style.css" }
  ],
  "crons": [
    { "path": "/cron/reputation-scores", "schedule": "0 8 1 * *" },
    { "path": "/cron/mark-conversions", "schedule": "0 8 * * *" }
  ]
}