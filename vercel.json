{
  "builds": [
    { "src": "server/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/css/(.*)", "dest": "/public/css/$1" },
    { "src": "/js/(.*)", "dest": "/public/js/$1" },
    { "src": "/images/(.*)", "dest": "/public/images/$1" },
    { "src": "/components/(.*)", "dest": "/public/components/$1" },
    { "src": "/blog/(.*)", "dest": "/public/blog/$1" },
    { "src": "/funnel/(.*)", "dest": "/public/funnel/$1" },
    { "src": "/style.css", "dest": "/public/style.css" },
    { "src": "/site.webmanifest", "dest": "/public/site.webmanifest" },
    { "src": "/apple-touch-icon.png", "dest": "/public/apple-touch-icon.png" },
    { "src": "/favicon.ico", "dest": "/public/favicon.ico" },
    { "src": "/favicon-16x16.png", "dest": "/public/favicon-16x16.png" },
    { "src": "/favicon-32x32.png", "dest": "/public/favicon-32x32.png" },
    { "src": "/robots.txt", "dest": "/public/robots.txt" },
    { "src": "/sitemap.xml", "dest": "/public/sitemap.xml" },
    { "src": "/(.*)\\.html", "dest": "/public/$1.html" },
    { "src": "/stripe-webhook", "dest": "server/index.js" },
    { "src": "/create-checkout", "dest": "server/index.js" },
    { "src": "/create-business", "dest": "server/index.js" },
    { "src": "/verify-login", "dest": "server/index.js" },
    { "src": "/session", "dest": "server/index.js" },
    { "src": "/logout", "dest": "server/index.js" },
    { "src": "/update-business", "dest": "server/index.js" },
    { "src": "/change-password", "dest": "server/index.js" },
    { "src": "/stats/(.*)", "dest": "server/index.js" },
    { "src": "/subscription-status/(.*)", "dest": "server/index.js" },
    { "src": "/restore-session/(.*)", "dest": "server/index.js" },
    { "src": "/reputation/(.*)", "dest": "server/index.js" },
    { "src": "/review-growth/(.*)", "dest": "server/index.js" },
    { "src": "/sentiment/(.*)", "dest": "server/index.js" },
    { "src": "/predict-channel/(.*)", "dest": "server/index.js" },
    { "src": "/generate-reply", "dest": "server/index.js" },
    { "src": "/analyse-competitor", "dest": "server/index.js" },
    { "src": "/update-funnel", "dest": "server/index.js" },
    { "src": "/send-sms", "dest": "server/index.js" },
    { "src": "/send-email", "dest": "server/index.js" },
    { "src": "/feedback", "dest": "server/index.js" },
    { "src": "/positive", "dest": "server/index.js" },
    { "src": "/rating", "dest": "server/index.js" },
    { "src": "/review-click", "dest": "server/index.js" },
    { "src": "/transcribe-voice/(.*)", "dest": "server/index.js" },
    { "src": "/qr-download/(.*)", "dest": "server/index.js" },
    { "src": "/create-nfc-checkout", "dest": "server/index.js" },
    { "src": "/agency/clients", "dest": "server/index.js" },
    { "src": "/agency/create-client", "dest": "server/index.js" },
    { "src": "/agency/switch-client/(.*)", "dest": "server/index.js" },
    { "src": "/agency/exit-client-mode", "dest": "server/index.js" },
    { "src": "/agency/remove-client/(.*)", "dest": "server/index.js" },
    { "src": "/agency/earnings", "dest": "server/index.js" },
    { "src": "/update-agency-settings", "dest": "server/index.js" },
    { "src": "/billing-portal", "dest": "server/index.js" },
    { "src": "/cancel-subscription", "dest": "server/index.js" },
    { "src": "/reactivate-subscription", "dest": "server/index.js" },
    { "src": "/api/(.*)", "dest": "server/index.js" },
    { "src": "/cron/(.*)", "dest": "server/index.js" },
    { "src": "/r/(.*)", "dest": "server/index.js" },
    { "src": "/wall/(.*)", "dest": "server/index.js" },
    { "src": "/milestone/(.*)", "dest": "server/index.js" },
    { "src": "/affiliate-stats/(.*)", "dest": "server/index.js" },
    { "src": "/partner-info/(.*)", "dest": "server/index.js" },
    { "src": "/contact", "dest": "server/index.js" },
    { "src": "/debug-env", "dest": "server/index.js" },
    { "src": "/debug-db-check", "dest": "server/index.js" },
    { "src": "/debug-supabase-info", "dest": "server/index.js" },
    { "src": "/health", "dest": "server/index.js" }
  ],
  "crons": [
    { "path": "/cron/reputation-scores", "schedule": "0 8 1 * *" },
    { "path": "/cron/mark-conversions", "schedule": "0 8 * * *" }
  ]
}