{
  "version": 2,
  "builds": [
    { "src": "server/index.js", "use": "@vercel/node" },
    { "src": "public/css/**", "use": "@vercel/static" },
    { "src": "public/js/**", "use": "@vercel/static" },
    { "src": "public/images/**", "use": "@vercel/static" },
    { "src": "public/components/**", "use": "@vercel/static" },
    { "src": "public/blog/**", "use": "@vercel/static" },
    { "src": "public/funnel/**", "use": "@vercel/static" },
    { "src": "public/*.html", "use": "@vercel/static" },
    { "src": "public/*.webmanifest", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/css/(.*)", "dest": "/public/css/$1" },
    { "src": "/js/(.*)", "dest": "/public/js/$1" },
    { "src": "/images/(.*)", "dest": "/public/images/$1" },
    { "src": "/components/(.*)", "dest": "/public/components/$1" },
    { "src": "/blog/(.*)", "dest": "/public/blog/$1" },
    { "src": "/funnel/(.*)", "dest": "/public/funnel/$1" },
    { "src": "/(.*)\\.(css|js|png|jpg|jpeg|gif|svg|ico|webmanifest|txt|xml|html)", "dest": "/public/$1.$2" },
    { "src": "/(.*)", "dest": "server/index.js" }
  ],
  "crons": [
    { "path": "/cron/reputation-scores", "schedule": "0 8 1 * *" },
    { "path": "/cron/mark-conversions", "schedule": "0 8 * * *" },
    { "path": "/cron/weekly-digest", "schedule": "0 9 * * 1" }
  ]
}